<Window x:Class="EquipmentMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设备监控系统" Height="450" Width="800">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 控制区域 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnConnect" Content="连接设备" Width="80" Margin="5" Click="BtnConnect_Click"/>
            <Button x:Name="btnStart" Content="开始采集" Width="80" Margin="5" Click="BtnStart_Click"/>
            <TextBlock Text="当前值：" VerticalAlignment="Center" Margin="20,0,5,0"/>
            <TextBox x:Name="txtCurrentValue" Width="100" Text="0" IsReadOnly="True" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 数据显示区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- 历史数据表格 -->
            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                <TextBlock Text="历史数据" FontWeight="Bold" Margin="0,0,0,5"/>
                <ListView x:Name="listData" Height="200">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="时间" Width="120" DisplayMemberBinding="{Binding Time}"/>
                            <GridViewColumn Header="值" Width="80" DisplayMemberBinding="{Binding Value}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>

            <!-- 数据可视化区域 (预留) -->
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="5">
                <TextBlock Text="实时曲线将显示在这里" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Center" 
                           Foreground="Gray"/>
            </Border>
        </Grid>
    </Grid>
</Window>